{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run test:e2e)",
      "Bash(npm run test:e2e:ui)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(bash scripts/deploy.sh)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git reset --hard)",
      "Bash(firebase deploy)",
      "Bash(rm -rf:*)"
    ]
  }
}
