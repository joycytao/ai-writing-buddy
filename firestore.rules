rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /artifacts/{appId}/users/{uid}/journals/{journalId} {
      allow read, write: if isOwner(uid);
    }

    match /artifacts/{appId}/users/{uid}/cloudReferences/{referenceId} {
      allow read, write: if isOwner(uid);
    }

    match /artifacts/{appId}/users/{uid}/settings/{settingId} {
      allow read, write: if isOwner(uid);
    }

    match /artifacts/{appId}/users/{uid}/wordBanks/{featureId}/words/{wordId} {
      allow read, write: if isOwner(uid);
    }

    match /artifacts/{appId}/public/data/journals/{entryId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
